@page "/notizen"
@rendermode InteractiveServer
@implements IDisposable

@inject Einsatzueberwachung.Mobile.Services.MobileApiClient ApiClient
@inject Einsatzueberwachung.Mobile.Services.MobileSignalRClient SignalRClient

<PageTitle>Notizen</PageTitle>

<section class="mobile-card">
    <h1><i class="bi bi-journal-text me-2"></i>Notizen</h1>
    <button class="btn btn-outline-secondary mobile-btn mb-2" @onclick="RefreshNotesAsync"><i class="bi bi-arrow-clockwise me-1"></i>Aktualisieren</button>

    <EditForm OnSubmit="AddNoteAsync">
        <div class="mobile-field">
            <label for="noteSource">Quelle</label>
            <InputSelect id="noteSource" class="form-select" @bind-Value="_sourceId">
                <option value="einsatzleitung">Einsatzleitung</option>
                @foreach (var team in _teams)
                {
                    <option value="@team.TeamId">@team.TeamName</option>
                }
            </InputSelect>
        </div>
        <div class="mobile-field">
            <label for="noteText">Neue Notiz</label>
            <InputTextArea id="noteText" class="form-control" @bind-Value="_text" />
        </div>
        <button class="btn btn-primary mobile-btn" type="submit"><i class="bi bi-send me-1"></i>Senden</button>
    </EditForm>

    <PullToRefreshPanel OnRefresh="RefreshNotesAsync">
        <div class="message-list">
            @foreach (var note in _notes)
            {
                <article class="message-item">
                    <header>
                        <strong>@note.SourceTeamName</strong>
                        <span>@note.FormattedTimestamp</span>
                    </header>
                    <p>@note.Text</p>

                    @if (note.Replies.Count > 0)
                    {
                        <div class="small mt-2">
                            @foreach (var reply in note.Replies.OrderBy(r => r.Timestamp))
                            {
                                <div class="border-start ps-2 mb-1">
                                    <div class="text-muted">@reply.SourceTeamName · @reply.FormattedTimestamp</div>
                                    <div>@reply.Text</div>
                                </div>
                            }
                        </div>
                    }

                    <div class="input-group input-group-sm mt-2">
                        <select class="form-select" style="max-width: 10rem;"
                                value="@GetReplySourceId(note.Id)"
                                @onchange="e => SetReplySourceId(note.Id, e.Value?.ToString())">
                            <option value="einsatzleitung">Einsatzleitung</option>
                            @foreach (var team in _teams)
                            {
                                <option value="@team.TeamId">@team.TeamName</option>
                            }
                        </select>
                        <input class="form-control"
                               placeholder="Antwort"
                               value="@GetReplyText(note.Id)"
                               @oninput="e => SetReplyText(note.Id, e.Value?.ToString())" />
                        <button class="btn btn-outline-primary" @onclick="() => AddReplyAsync(note.Id)">Antworten</button>
                    </div>
                </article>
            }
        </div>
    </PullToRefreshPanel>
</section>

@code {
    private string _text = string.Empty;
    private string _sourceId = "einsatzleitung";
    private readonly List<Einsatzueberwachung.Domain.Models.GlobalNotesEntry> _notes = new();
    private readonly List<Einsatzueberwachung.Domain.Models.Team> _teams = new();
    private readonly Dictionary<string, string> _replyTexts = new();
    private readonly Dictionary<string, string> _replySourceIds = new();

    protected override async Task OnInitializedAsync()
    {
        SignalRClient.UpdateReceived += OnUpdateReceived;
        await SignalRClient.EnsureConnectedAsync();
        await RefreshNotesAsync();
    }

    private async Task AddNoteAsync()
    {
        if (string.IsNullOrWhiteSpace(_text))
        {
            return;
        }

        var (sourceTeamId, sourceTeamName, createdBy) = ResolveSource(_sourceId);
        await ApiClient.AddNoteAsync(_text.Trim(), "Notiz", sourceTeamId, sourceTeamName, createdBy);
        _text = string.Empty;
        await RefreshNotesAsync();
    }

    private async Task RefreshNotesAsync()
    {
        var teams = await ApiClient.GetTeamsAsync();
        var notes = await ApiClient.GetNotesAsync("notiz");
        _teams.Clear();
        _teams.AddRange(teams.OrderBy(t => t.TeamName));
        _notes.Clear();
        _notes.AddRange(notes);
        await InvokeAsync(StateHasChanged);
    }

    private async Task AddReplyAsync(string noteId)
    {
        _replyTexts.TryGetValue(noteId, out var text);
        if (string.IsNullOrWhiteSpace(text))
        {
            return;
        }

        var sourceId = GetReplySourceId(noteId);
        var (sourceTeamId, sourceTeamName, createdBy) = ResolveSource(sourceId);
        await ApiClient.AddReplyAsync(noteId, text.Trim(), sourceTeamId, sourceTeamName, createdBy);
        _replyTexts[noteId] = string.Empty;
        await RefreshNotesAsync();
    }

    private string GetReplyText(string noteId)
    {
        return _replyTexts.TryGetValue(noteId, out var text) ? text : string.Empty;
    }

    private void SetReplyText(string noteId, string? text)
    {
        _replyTexts[noteId] = text ?? string.Empty;
    }

    private string GetReplySourceId(string noteId)
    {
        if (!_replySourceIds.TryGetValue(noteId, out var sourceId) || string.IsNullOrWhiteSpace(sourceId))
        {
            _replySourceIds[noteId] = "einsatzleitung";
        }

        return _replySourceIds[noteId];
    }

    private void SetReplySourceId(string noteId, string? sourceId)
    {
        _replySourceIds[noteId] = string.IsNullOrWhiteSpace(sourceId) ? "einsatzleitung" : sourceId;
    }

    private (string SourceTeamId, string SourceTeamName, string CreatedBy) ResolveSource(string sourceId)
    {
        if (string.IsNullOrWhiteSpace(sourceId) || sourceId == "einsatzleitung")
        {
            return ("einsatzleitung", "Einsatzleitung", "Einsatzleitung");
        }

        var team = _teams.FirstOrDefault(t => t.TeamId == sourceId);
        if (team is null)
        {
            return ("einsatzleitung", "Einsatzleitung", "Einsatzleitung");
        }

        return (team.TeamId, team.TeamName, team.TeamName);
    }

    private void OnUpdateReceived(string eventName, string payload)
    {
        _ = payload;
        if (eventName.StartsWith("note.", StringComparison.OrdinalIgnoreCase)
            || eventName.StartsWith("team.", StringComparison.OrdinalIgnoreCase)
            || eventName.Equals("einsatz.changed", StringComparison.OrdinalIgnoreCase))
        {
            _ = InvokeAsync(async () =>
            {
                await RefreshNotesAsync();
                StateHasChanged();
            });
        }
    }

    public void Dispose()
    {
        SignalRClient.UpdateReceived -= OnUpdateReceived;
    }
}
