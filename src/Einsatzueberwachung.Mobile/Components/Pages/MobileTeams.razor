@page "/teams"
@rendermode InteractiveServer

@implements IDisposable
@inject Einsatzueberwachung.Mobile.Services.MobileApiClient ApiClient
@inject Einsatzueberwachung.Mobile.Services.MobileSignalRClient SignalRClient

<PageTitle>Teams</PageTitle>

<section class="mobile-card">
    <h1><i class="bi bi-people me-2"></i>Team-Uebersicht</h1>
    <p class="subline">Aktive Teams mit Status und Laufzeit</p>
    <button class="btn btn-outline-secondary mobile-btn mb-2" @onclick="RefreshTeamsAsync"><i class="bi bi-arrow-clockwise me-1"></i>Aktualisieren</button>

    <PullToRefreshPanel OnRefresh="RefreshTeamsAsync">
        @if (_teams.Count == 0)
        {
            <p class="empty-state">Keine aktiven Teams vorhanden.</p>
        }
        else
        {
            @foreach (var team in _teams)
            {
                <article class="team-item @GetTeamStatusClass(team)">
                    <header>
                        <strong>@team.TeamName</strong>
                        <span>@FormatElapsed(team.ElapsedTime)</span>
                    </header>
                    <p>HF: @team.HundefuehrerName | Helfer: @team.HelferName</p>
                    @if (!string.IsNullOrWhiteSpace(team.DogName))
                    {
                        <p>Hund: @team.DogName</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(team.SearchAreaName))
                    {
                        <p>Gebiet: @team.SearchAreaName</p>
                    }
                </article>
            }
        }
    </PullToRefreshPanel>
</section>

@code {
    private readonly List<Einsatzueberwachung.Domain.Models.Team> _teams = new();

    protected override async Task OnInitializedAsync()
    {
        SignalRClient.UpdateReceived += OnUpdateReceived;
        await SignalRClient.EnsureConnectedAsync();
        await RefreshTeamsAsync();
    }

    private async Task RefreshTeamsAsync()
    {
        var teams = await ApiClient.GetTeamsAsync();
        _teams.Clear();
        _teams.AddRange(teams);
    }

    private static string FormatElapsed(TimeSpan elapsed) =>
        $"{elapsed.Hours:D2}:{elapsed.Minutes:D2}:{elapsed.Seconds:D2}";

    private static string GetTeamStatusClass(Einsatzueberwachung.Domain.Models.Team team)
    {
        var minutes = (int)team.ElapsedTime.TotalMinutes;

        if (minutes >= team.SecondWarningMinutes)
        {
            return "status-critical";
        }

        if (minutes >= team.FirstWarningMinutes)
        {
            return "status-warning";
        }

        return "status-ok";
    }

    private void OnUpdateReceived(string eventName, string payload)
    {
        _ = payload;
        if (eventName.StartsWith("team.", StringComparison.OrdinalIgnoreCase)
            || eventName.Equals("einsatz.changed", StringComparison.OrdinalIgnoreCase))
        {
            _ = InvokeAsync(async () =>
            {
                await RefreshTeamsAsync();
                StateHasChanged();
            });
        }
    }

    public void Dispose()
    {
        SignalRClient.UpdateReceived -= OnUpdateReceived;
    }
}
